# Stack 100% gratuito (registo opcional onde indicado)
#
# Obrigatório para meteo:
OPENWEATHERMAP_API_KEY=

# Opcional — stats + Table Stakes auditor (grátis, 10 req/min, cache 24h):
FOOTBALL_DATA_API_KEY=

# Opcional — API-Football / API-Sports v3 (grátis ~100 req/dia):
# Tester: https://dashboard.api-football.com/soccer/tester
API_FOOTBALL_KEY=

# Persistência — local usa ./data ; Render usa /var/data (+ disco opcional)
# DATA_DIR=/var/data
# Cache histórico (fecho + estilo): python scripts/refresh_historical_profiles.py --leagues PPL
# data/historical/team_profiles.jsonl — fonte CSV football-data.co.uk (grátis)
#
# Cache Transfermarkt: data/transfermarkt/*.jsonl (valor, treinadores, árbitro, lesões)
# API pública (felipeall) — sync plantel + lesões: python scripts/refresh_transfermarkt_cache.py --sync Benfica,Maritimo
# TRANSFERMARKT_API_URL=https://transfermarkt-api.fly.dev

# Opcional — Web Push no servidor (gerar par VAPID com: npx web-push generate-vapid-keys)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# IA live autónoma (Grok) — obrigatória para reasoning_pt no separador IA.
# Requer créditos/licença em https://console.x.ai
# XAI_API_KEY=
# Router automático: grok-4-1-fast (ritmo normal) ↔ grok-4.3 (momentos críticos)
# IA_LLM_MODEL_FAST=grok-4-1-fast
# IA_LLM_MODEL_DEEP=grok-4.3
# IA_LLM_MODEL=grok-4.3   # força um único modelo (desactiva router)

# Login PWA (opcional) — activa com AUTH_ENABLED=1 ou define AUTH_USERNAME
# Sem login: só pré-jogo + dicas IA. Com login aprovado: bots, ao vivo e histórico.
# Novas inscrições ficam pendentes até o admin (AUTH_USERNAME) aprovar em Definições.
# AUTH_ENABLED=1
# AUTH_USERNAME=admin
# AUTH_PASSWORD=altera-esta-passe
# AUTH_SECRET=string-longa-aleatoria-para-sessoes
# AUTH_SESSION_TTL_DAYS=30   # opcional — sessão automática (máx. 90 dias; default 7)
# AUTH_ADMIN2_USERNAME=pedromja
# AUTH_ADMIN2_PASSWORD=altera-esta-passe

# Link do banner «VIVE o MOMENTO!» no pré-jogo (ou em web/branding.json → moment_banner_url)
# MOMENT_BANNER_URL=https://exemplo.com

# Auto-aprendizagem — ajusta min_score com base em greens/reds (1=activo, 0=desactiva)
AUTO_TUNE=1

# Odds checker (The-Odds-API) — cruza ESPN com 1xBet/nicho e usa a pior odd:
# THE_ODDS_API_KEY=

# Opcional — sincronizar chaves para Render (scripts/render_sync_env.ps1):
# RENDER_API_KEY=

# Jogos + odds: ESPN/TheSportsDB/Bing (automático, sem chave)
# Notícias: Bing web search (automático, sem chave)